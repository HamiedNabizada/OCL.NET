  <RoleClassLib Name="VDI_FPD_RoleClassLib">
    <Description>Semantic model of the FPD per VDI/VDE 3682. Flat layout with explicit inheritance via RefBaseClassPath.</Description>
    <Version>1.0.0</Version>
    <RoleClass Name="FPD_Process" RefBaseClassPath="AutomationMLBaseLibrariesAMLEd22_11_0@AutomationMLBaseRoleClassLib/AutomationMLBaseRole/Structure">
      <Description>Process (Part 2, Fig. 2). Aggregates states (2..*), system limit (1), and process operators (1..*).</Description>
      <Version>1.0.0</Version>
      <Attribute Name="refObj" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_AttributeTypeLib/refObj">
        <Description>IDREF to the parent process operator whose decomposition this process represents.</Description>
      </Attribute>
    </RoleClass>
    <RoleClass Name="FPD_SystemLimit">
      <Description>System limit (Part 1, p. 9). Peer aggregate of the process, not a container.</Description>
      <Version>1.0.0</Version>
      <Attribute Name="Identification" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_AttributeTypeLib/FPD_Identification">
        <Attribute Name="uniqueIdent" AttributeDataType="xs:string" />
        <Attribute Name="longName" AttributeDataType="xs:string" />
        <Attribute Name="shortName" AttributeDataType="xs:string" />
        <Attribute Name="versionNumber" AttributeDataType="xs:string" />
        <Attribute Name="revisionNumber" AttributeDataType="xs:string" />
      </Attribute>
      <Attribute Name="ViewInformation" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_DI_AttributeTypeLib/FPD_Bounds">
        <Attribute Name="position" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_DI_AttributeTypeLib/FPD_Point">
          <Attribute Name="x" AttributeDataType="xs:double" />
          <Attribute Name="y" AttributeDataType="xs:double" />
        </Attribute>
        <Attribute Name="width" AttributeDataType="xs:double" />
        <Attribute Name="height" AttributeDataType="xs:double" />
      </Attribute>
    </RoleClass>
    <RoleClass Name="FPD_Object" RefBaseClassPath="AutomationMLBaseLibrariesAMLEd22_11_0@AutomationMLBaseRoleClassLib/AutomationMLBaseRole">
      <Description>Abstract base for all FPB objects (Part 1, p. 4: product, energy, information, process operator, technical resource).</Description>
      <Version>1.0.0</Version>
      <Attribute Name="Identification" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_AttributeTypeLib/FPD_Identification">
        <Attribute Name="uniqueIdent" AttributeDataType="xs:string" />
        <Attribute Name="longName" AttributeDataType="xs:string" />
        <Attribute Name="shortName" AttributeDataType="xs:string" />
        <Attribute Name="versionNumber" AttributeDataType="xs:string" />
        <Attribute Name="revisionNumber" AttributeDataType="xs:string" />
      </Attribute>
      <Attribute Name="Characteristics" AttributeDataType="xs:string">
        <Description>Container for characteristics (Part 2, Fig. 3).</Description>
      </Attribute>
      <Attribute Name="ViewInformation" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_DI_AttributeTypeLib/FPD_Bounds">
        <Attribute Name="position" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_DI_AttributeTypeLib/FPD_Point">
          <Attribute Name="x" AttributeDataType="xs:double" />
          <Attribute Name="y" AttributeDataType="xs:double" />
        </Attribute>
        <Attribute Name="width" AttributeDataType="xs:double" />
        <Attribute Name="height" AttributeDataType="xs:double" />
      </Attribute>
    </RoleClass>
    <RoleClass Name="FPD_State" RefBaseClassPath="VDI_FPD_RoleClassLib/FPD_Object">
      <Description>Abstract state (Part 2, Fig. 2). Inherits Identification and Characteristics from FPD_Object.</Description>
      <Version>1.0.0</Version>
      <Attribute Name="refObj" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_AttributeTypeLib/refObj">
        <Description>IDREF to the original state instance that this boundary state represents. Always points to the top-level original, regardless of decomposition depth.</Description>
      </Attribute>
    </RoleClass>
    <RoleClass Name="FPD_Product" RefBaseClassPath="VDI_FPD_RoleClassLib/FPD_State">
      <Version>1.0.0</Version>
    </RoleClass>
    <RoleClass Name="FPD_Energy" RefBaseClassPath="VDI_FPD_RoleClassLib/FPD_State">
      <Version>1.0.0</Version>
    </RoleClass>
    <RoleClass Name="FPD_Information" RefBaseClassPath="VDI_FPD_RoleClassLib/FPD_State">
      <Version>1.0.0</Version>
    </RoleClass>
    <RoleClass Name="FPD_ProcessOperator" RefBaseClassPath="VDI_FPD_RoleClassLib/FPD_Object">
      <Description>Process operator (Part 2, Fig. 2). Inherits Identification and Characteristics from FPD_Object.</Description>
      <Version>1.0.0</Version>
      <Attribute Name="refProcess" AttributeDataType="xs:string" RefAttributeType="VDI_FPD_AttributeTypeLib/refObj">
        <Description>IDREF to the child process that decomposes this operator. Empty if the operator is not further decomposed.</Description>
      </Attribute>
    </RoleClass>
    <RoleClass Name="FPD_TechnicalResource" RefBaseClassPath="VDI_FPD_RoleClassLib/FPD_Object">
      <Description>Technical resource (Part 1, p. 9). Located outside the system limit, associated via usage.</Description>
      <Version>1.0.0</Version>
    </RoleClass>
  </RoleClassLib>
