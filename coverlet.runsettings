<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <!-- Exclude ANTLR-generated lexer/parser/visitor (emitted under obj/). -->
          <ExcludeByFile>**/obj/**/*.cs</ExcludeByFile>
          <Exclude>[*]OCL.NET.Core.Grammar.*</Exclude>
          <SkipAutoProps>true</SkipAutoProps>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
